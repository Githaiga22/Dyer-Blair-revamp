# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local reference assets (raw screenshots, design files — not part of the build)
/assets/landingpage1.png
/assets/landingpage2.png
/assets/landingpage3.png

# local dev scripts (utility scripts, not production code)
commit_files.py

# local IDE / OS files
.idea/
.vscode/settings.json
*.swp
*.swo
Thumbs.db

# local environment overrides
.env.local
.env.development.local
.env.test.local
.env.production.local
